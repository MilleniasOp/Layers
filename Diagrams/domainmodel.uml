@startuml Domain Model
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam roundcorner 5
skinparam class {
    BackgroundColor Beige
    ArrowColor #2A5D9A
    BorderColor #2A5D9A
}

class User {
  - username: String
  - password: String
  - role: String
}

class Customer {
  - orderHistory: List<Order>
}

class Employee {
}

class Owner {
}

class Attendance {
  - id: String
  - username: String
  - clockIn: String
  - clockOut: String
}

class Order {
  - orderId: String
  - username: String
  - items: List<OrderItem>
  - status: Status
  - totalPrice: double
  - placedAt: String
}

class OrderItem {
  - menuItem: Product
  - quantity: int
}

class Product {
  - itemId: String
  - name: String
  - description: String
  - price: double
  - available: boolean
}

class Recipe {
  - recipeId: String
  - productName: String
  - ingredients: List<String>
  - measurements: List<String>
}

class Task {
  - taskId: String
  - description: String
  - assignedTo: String
  - status: String
  - createdDate: LocalDateTime
  - completedPeriod: String
}

class Report {
  - ReportID: String
  - taskId: String
  - description: String
  - assignedTo: String
  - status: String
  - createdDate: LocalDateTime
}

class Payroll {
  - username: String
  - tasksCompleted: int
  - totalhours: int
  - taskPay: double
  - attendancePay: double
  - totalPay: double
  - period: String
}

User <|-- Customer
User <|-- Employee
User <|-- Owner

Customer "1" --> "0..*" Order : places 
Order "1" --> "1..*" OrderItem : contains 
OrderItem "1" --> "1" Product : references 

Recipe "1..*" --> "1" Product : for 

Employee "1" --> "0..*" Task : assigned to
Report "1" --> "1" Task : contains

Employee "1" --> "0..*" Attendance : has 
Employee "1" --> "0..*" Payroll : has 

@enduml