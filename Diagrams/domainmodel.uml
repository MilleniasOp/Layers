@startuml
title Domain Model

' --- Styling ---
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 80
skinparam ranksep 80
skinparam roundcorner 10
skinparam shadowing false

skinparam class {
    BackgroundColor Beige
    ArrowColor #2A5D9A
    BorderColor #2A5D9A
    HeaderBackgroundColor #E6D5B8
}

' --- User Hierarchy ---
class User {
  - username: String
  - password: String
  - role: String
}

class Customer {
  - orderHistory: List<Order>
}

class Employee {
}

class Owner {
}

User <|-- Customer
User <|-- Employee
User <|-- Owner

' --- Sales & Inventory Cluster ---
together {
    class Product {
      - itemId: String
      - name: String
      - price: double
      - available: boolean
    }
    
    class Recipe {
      - recipeId: String
      - productName: String
      - ingredients: List<String>
    }
    
    class Order {
      - orderId: String
      - status: Status
      - totalPrice: double
    }
    
    class OrderItem {
      - quantity: int
    }
}

' --- Operations & HR Cluster ---
together {
    class Task {
      - taskId: String
      - description: String
      - status: String
    }
    
    class Report {
      - ReportID: String
    }
    
    class Attendance {
      - clockIn: String
      - clockOut: String
    }
    
    class Payroll {
      - totalPay: double
      - period: String
    }
}

' --- Relationships ---

' Sales Flow
Customer "1" -- "0..*" Order : places 
Order "1" *-- "1..*" OrderItem : contains 
OrderItem "1" --> "1" Product : references 
Recipe "1..*" -- "1" Product : defines 

' Staff & Operations
Employee "1" -- "0..*" Task : assigned to 
Employee "1" -- "0..*" Attendance : records 
Employee "1" -- "0..*" Payroll : receives 
Report "1" -- "1" Task : documents 

' Owner Authority (Consolidated)
Owner "1" --> "1..*" Task : manages 
Owner "1" --> "1..*" Product : manages 
Owner "1" --> "1..*" Payroll : calculates 

@enduml