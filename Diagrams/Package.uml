@startuml
top to bottom direction

package "entity" as Entity {
    class User
    class Customer
    class Employee
    class Owner
    class Order
    class Product
    class Task
    class Attendance
    class Payroll
    class Recipe
    class Report
}

package "controller" as Controller {
    class Authenticator
    class OrderController
    class TaskController
    class ProductController
    class EmployeeController
    class FinanceController
    class ReportController
    class RecipeController
    class UserController
    class AttendanceController
    class AlertController
    class BrowseMenuController
}

package "boundary" as Boundary {
    package "pages" {
        class AuthenticatorUI
        class CustomerDashboardUI
        class EmployeeDashBoardUI
        class OwnerDashBoardUI
    }
    package "tabs" {
        class EmployeeTaskUI
        class FinanceUI
        class ProductUI
        class RecipeUI
        class ReportUI
        class TaskUI
        class UserUI
    }
}

Controller -down-> Entity : interacts
Boundary -down-> Controller : uses

@enduml