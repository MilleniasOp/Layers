@startuml
skinparam classAttributeIconSize 0
skinparam linetype ortho
skinparam nodesep 60
skinparam ranksep 80
hide methods

skinparam class {
    BackgroundColor Beige
    ArrowColor #2A5D9A
    BorderColor #2A5D9A
}

' --- Grouping into Packages for Layout Stability ---

package "Data Models" {
    class User
    class Product
    class Recipe
    class Order
    class OrderItem
    class Task
    class Report
    class Attendance
    class Payroll
}

package "Logic Controllers" {
    class Authenticator
    class ProductController
    class RecipeController
    class ReportController
    class TaskController
    class UserController
    class OrderController
    class AttendanceController
    class FinanceController
    class BrowseMenuController
    class EmployeeController
    class AlertController
    class SupabaseClient <<Utility>>
}

package "User Interface" {
    class AuthenticatorUI
    class CustomerDashboardUI
    class EmployeeDashBoardUI
    class OwnerDashBoardUI
    class EmployeeTaskUI
    class FinanceUI
    class ProductUI
    class RecipeUI
    class ReportUI
    class TaskUI
    class UserUI
}

' --- Structural Relationships ---
Order "1" --> "0..*" OrderItem : "contains"
OrderItem "1" --> "1" Product : "references"
Report "1" --> "1" Task : "generated from"

' --- Controller Dependencies ---
Authenticator ..> User : "fetches"
Authenticator ..> SupabaseClient : "uses"
FinanceController ..> Payroll : "manages"
ProductController ..> Product : "manages"
ProductController ..> SupabaseClient : "uses"
RecipeController ..> Recipe : "manages"
RecipeController ..> SupabaseClient : "uses"
ReportController ..> Report : "generates"
ReportController ..> Task : "reads"
ReportController ..> SupabaseClient : "uses"
TaskController ..> Task : "manages"
TaskController ..> SupabaseClient : "uses"
TaskController ..> AlertController: "uses"
UserController ..> User : "manages"
UserController ..> SupabaseClient : "uses"
OrderController ..> Order : "builds"
OrderController ..> Product : "uses"
OrderController ..> BrowseMenuController : "uses"
BrowseMenuController ..> Product : "reads"
BrowseMenuController ..> SupabaseClient : "uses"
EmployeeController ..> AttendanceController: "uses"
AttendanceController ..> Attendance: "manages"

' --- UI Dependencies ---
ProductUI ..> ProductController : "uses"
RecipeUI ..> RecipeController : "uses"
ReportUI ..> ReportController : "uses"
TaskUI ..> TaskController : "uses"
FinanceUI ..> FinanceController: "uses"
UserUI ..> UserController: "uses"

OwnerDashBoardUI ..> ProductUI : "renders"
OwnerDashBoardUI ..> RecipeUI : "renders"
OwnerDashBoardUI ..> ReportUI : "renders"
OwnerDashBoardUI ..> TaskUI : "renders"
OwnerDashBoardUI ..> FinanceUI : "renders"
OwnerDashBoardUI ..> UserUI : "renders"

AuthenticatorUI ..> Authenticator : "uses"
AuthenticatorUI ..> OwnerDashBoardUI : "renders"
AuthenticatorUI ..> EmployeeDashBoardUI : "renders"
AuthenticatorUI ..> CustomerDashboardUI : "renders"

EmployeeDashBoardUI ..> EmployeeTaskUI : "renders"
EmployeeTaskUI ..> TaskController : "uses"
EmployeeTaskUI ..> EmployeeController: "uses"
CustomerDashboardUI ..> OrderController: "uses"

@enduml